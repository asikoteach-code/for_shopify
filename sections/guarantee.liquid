<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}">
  <div class="spacing-style guarantee-wrapper">
    {% if section.settings.heading != blank %}
      <div class="guarantee__header text-center">
        <h2 class="heading h2">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="guarantee__grid">
      {% for block in section.blocks %}
        <div class="guarantee__item" {{ block.shopify_attributes }}>
          <div class="guarantee__icon">{{ block.settings.icon }}</div>
          <h3 class="heading h4">{{ block.settings.title }}</h3>
          <p class="body-text">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.cta_button_label != blank %}
      <div class="guarantee__cta text-center">
        <a href="{{ section.settings.cta_button_link }}" class="button button--primary">
          {{ section.settings.cta_button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .guarantee-wrapper {
    max-width: 100%;
  }

  .guarantee__header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .guarantee__header h2 {
    margin-bottom: 0.5rem;
  }

  .guarantee__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .guarantee__item {
    text-align: center;
    padding: 2rem 1.5rem;
    background-color: rgba(93, 204, 200, 0.05);
    border-radius: 12px;
    border: 1px solid var(--color-border, #e0f2f0);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .guarantee__item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(93, 204, 200, 0.15);
  }

  .guarantee__icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .guarantee__item h3 {
    margin-bottom: 0.75rem;
    color: var(--color-foreground-heading, #2c3e50);
  }

  .guarantee__item p {
    color: var(--color-foreground, #5a5a5a);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .guarantee__cta {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border, #e0f2f0);
  }

  .button--primary {
    background-color: #5DCCC8;
    color: white;
    padding: 1rem 2rem;
    border-radius: 28px;
    border: none;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .button--primary:hover {
    background-color: #4bb3b0;
  }

  @media (max-width: 768px) {
    .guarantee__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .guarantee__item {
      padding: 1.5rem;
    }

    .guarantee__cta {
      margin-top: 2rem;
      padding-top: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Guarantee",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop with Confidence"
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "Call-to-Action Button Label",
      "default": "Start Shopping"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "Call-to-Action Button Link",
      "default": "/collections/all"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Scheme 1"
        }
      ]
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "default": "full",
      "options": [
        {
          "value": "full",
          "label": "Full"
        },
        {
          "value": "standard",
          "label": "Standard"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "guarantee_item",
      "name": "Guarantee Item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or HTML)",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Money-Back Guarantee"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Not satisfied? Get your money back within 30 days, no questions asked."
        }
      ]
    }
  ]
}
{% endschema %}
