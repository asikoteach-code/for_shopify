<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}">
  <div class="spacing-style before-after-wrapper" style="{%  render 'spacing-style', settings: section.settings %}">
    {% if section.settings.heading != blank %}
      <div class="before-after__header text-center">
        <h2 class="heading h2">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="body-text">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="before-after__container">
      <div class="before-after__column">
        <div class="before-after__label">Before</div>
        {% if section.settings.before_image != blank %}
          <img 
            src="{{ section.settings.before_image | image_url: width: 500 }}"
            alt="Before using our product"
            class="before-after__image"
          >
        {% else %}
          <div class="before-after__placeholder">Add before image</div>
        {% endif %}
      </div>

      <div class="before-after__column">
        <div class="before-after__label">After</div>
        {% if section.settings.after_image != blank %}
          <img 
            src="{{ section.settings.after_image | image_url: width: 500 }}"
            alt="After using our product"
            class="before-after__image"
          >
        {% else %}
          <div class="before-after__placeholder">Add after image</div>
        {% endif %}
      </div>
    </div>

    {% if section.settings.show_stats %}
      <div class="before-after__stats">
        {% for block in section.blocks %}
          <div class="stat__item" {{ block.shopify_attributes }}>
            <div class="stat__number">{{ block.settings.stat_number }}</div>
            <div class="stat__label">{{ block.settings.stat_label }}</div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .before-after-wrapper {
    max-width: 100%;
  }

  .before-after__header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .before-after__header h2 {
    margin-bottom: 0.5rem;
  }

  .before-after__container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .before-after__column {
    position: relative;
  }

  .before-after__label {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: rgba(93, 204, 200, 0.9);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-weight: 600;
    z-index: 10;
  }

  .before-after__image {
    width: 100%;
    height: auto;
    border-radius: 12px;
    display: block;
  }

  .before-after__placeholder {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f5f5f5;
    border: 2px dashed #ddd;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
  }

  .before-after__stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
    text-align: center;
  }

  .stat__item {
    padding: 1.5rem;
  }

  .stat__number {
    font-size: 2.5rem;
    font-weight: bold;
    color: #5DCCC8;
    margin-bottom: 0.5rem;
  }

  .stat__label {
    color: var(--color-foreground, #5a5a5a);
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .before-after__container {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .stat__number {
      font-size: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Before & After",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the Difference"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real results from real pet parents"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before Image"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After Image"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Show Statistics",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Scheme 1"
        }
      ]
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "default": "full",
      "options": [
        {
          "value": "full",
          "label": "Full"
        },
        {
          "value": "standard",
          "label": "Standard"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "settings": [
        {
          "type": "text",
          "id": "stat_number",
          "label": "Statistic Number",
          "default": "95%"
        },
        {
          "type": "text",
          "id": "stat_label",
          "label": "Statistic Label",
          "default": "Satisfaction Rate"
        }
      ]
    }
  ]
}
{% endschema %}
