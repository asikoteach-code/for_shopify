<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}">
  <div class="spacing-style" style="{%  render 'spacing-style', settings: section.settings %}">
    {% if section.settings.heading != blank %}
      <div class="how-it-works__header text-center">
        <h2 class="heading h2">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="body-text">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="how-it-works__grid">
      {% for block in section.blocks %}
        <div class="how-it-works__step" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="how-it-works__icon">
              {{ block.settings.icon }}
            </div>
          {% endif %}
          <h3 class="heading h4">{{ block.settings.step_title }}</h3>
          <p class="body-text">{{ block.settings.step_description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .how-it-works__header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .how-it-works__header h2 {
    margin-bottom: 0.5rem;
  }

  .how-it-works__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .how-it-works__step {
    text-align: center;
    padding: 1.5rem;
    border-radius: 12px;
    background-color: rgba(93, 204, 200, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .how-it-works__step:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(93, 204, 200, 0.15);
  }

  .how-it-works__icon {
    margin-bottom: 1rem;
    font-size: 3rem;
  }

  .how-it-works__step h3 {
    margin-bottom: 0.75rem;
    color: var(--color-foreground-heading, #2c3e50);
  }

  .how-it-works__step p {
    color: var(--color-foreground, #5a5a5a);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .how-it-works__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .how-it-works__step {
      padding: 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "How It Works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Simple steps for beautiful results"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Scheme 1"
        }
      ]
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "default": "full",
      "options": [
        {
          "value": "full",
          "label": "Full"
        },
        {
          "value": "standard",
          "label": "Standard"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_title",
          "label": "Step Title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "step_description",
          "label": "Step Description",
          "default": "Add your step description here"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or HTML)",
          "default": "1️⃣"
        }
      ]
    }
  ]
}
{% endschema %}
